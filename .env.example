# MsTechnics environment template
# Copy this file to `Config/.env` (or project root `.env`) and replace every placeholder.
# Never commit real secrets to git.

# Django
SECRET_KEY=<generate-with-python-c-secrets-token_urlsafe-64>
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,mstechnics.ru,www.mstechnics.ru
ENABLE_API_DOCS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,https://mstechnics.ru,https://www.mstechnics.ru
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,https://mstechnics.ru,https://www.mstechnics.ru

# Database (PostgreSQL)
DATABASE_NAME=mstechnics
DATABASE_USER=mstechnics
DATABASE_PASSWORD=<set-strong-database-password>
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Telegram / notifications
# Leave empty until the bot token is issued.
TELEGRAM_BOT_TOKEN=<set-telegram-bot-token>
TELEGRAM_TIMEOUT_SEC=30
# TELEGRAM_PROXY_URL=socks5://user:password@your-vps.example.com:1080

# MAX / fallback channel
# Leave empty until the bot token is issued.
MAX_BOT_TOKEN=<set-max-bot-token>
MAX_API_BASE=https://platform-api.max.ru
MAX_WEBHOOK_SECRET=<generate-with-python-c-secrets-token_urlsafe-32>
MAX_TIMEOUT_SEC=30

# Email fallback
DEFAULT_FROM_EMAIL=noreply@mstechnics.ru

# Sentry / prod logging
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# VNNOX Gmail alarms
VNNOX_ALARM_NOTIFY_THRESHOLD_MINUTES=15
GOOGLE_CLIENT_SECRET_PATH=Config/client_secret.json
