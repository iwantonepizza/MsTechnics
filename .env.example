# =============================================================================
# MsTechnics — пример конфига окружения
# Скопируй в .env и заполни реальными значениями.
# НЕ КОММИТЬ файл с реальными секретами!
# =============================================================================

# Django
SECRET_KEY=your-very-long-secret-key-change-me-in-production
DEBUG=True

# Database (PostgreSQL)
DATABASE_NAME=mstechnics
DATABASE_USER=mstechnics
DATABASE_PASSWORD=change_me
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Telegram / notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_TIMEOUT_SEC=30
# SOCKS5/HTTP proxy через зарубежный VPS. Пароль хранить только в password manager / real .env.
# TELEGRAM_PROXY_URL=socks5://user:password@your-vps.example.com:1080

# MAX / fallback channel
MAX_BOT_TOKEN=
MAX_API_BASE=https://platform-api.max.ru
MAX_WEBHOOK_SECRET=
MAX_TIMEOUT_SEC=30

# Email fallback
DEFAULT_FROM_EMAIL=noreply@mstechnics.local

# Sentry / prod logging
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# VNNOX Gmail alarms
VNNOX_ALARM_NOTIFY_THRESHOLD_MINUTES=15

# Google OAuth (создать новый после отзыва старого в Google Cloud Console)
# GOOGLE_CLIENT_SECRET_PATH=Config/client_secret.json
